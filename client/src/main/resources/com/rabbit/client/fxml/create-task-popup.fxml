<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.CreateTaskPopupController"
           styleClass="overlay"
           onMouseClicked="#handleOverlayClick">

      <VBox fx:id="popupCard"
          maxWidth="680"
          prefWidth="600"
          maxHeight="800"
          fillWidth="true"
          alignment="CENTER"
          StackPane.alignment="CENTER"
          spacing="0"
          onMouseClicked="#consumeClick"
          styleClass="popup-card">

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="popup-header">
            <Label text="%create_task_title" styleClass="popup-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleCancel" styleClass="close-btn"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    fitToHeight="true"
                    styleClass="popup-scroll">
            <VBox spacing="18" styleClass="popup-body">
                <padding><Insets top="24" left="24" right="24" bottom="16"/></padding>

                <VBox spacing="6">
                    <Label text="%task_name_label" styleClass="field-label"/>
                    <TextField fx:id="titleField" promptText="%enter_task_name" styleClass="input-white"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="%description_label" styleClass="field-label"/>
                    <TextArea fx:id="descriptionField" promptText="%describe_task"
                              prefHeight="100" wrapText="true" styleClass="input-white"/>
                </VBox>

                <Separator styleClass="divider"/>

                <HBox spacing="16" alignment="TOP_LEFT">
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <DatePicker fx:id="deadlinePicker" promptText="%select_deadline"
                                    maxWidth="1.7976931348623157E308" styleClass="date-input"/>
                        <HBox styleClass="status-box" alignment="CENTER_LEFT" spacing="8">
                            <Label text="%status_prefix" styleClass="status-label"/>
                            <Label text="%backlog" styleClass="status-value"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="priority-box-container">
                        <Label text="%priority_label" styleClass="field-label" maxWidth="1.7976931348623157E308"/>
                        <HBox fx:id="priorityBox" spacing="10" alignment="CENTER"/>
                    </VBox>
                </HBox>

                <Separator styleClass="divider"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="%assigned_label2" styleClass="assigned-label"/>
                    <ComboBox fx:id="assigneeCombo" promptText="%pick_worker"
                              maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                              styleClass="combo-input"/>
                </HBox>

                <VBox spacing="12" styleClass="ai-card">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🐇" styleClass="ai-icon"/>
                        <Label text="%ai_header" styleClass="ai-header-text"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER">
                        <TextField fx:id="skillsField"
                                   promptText="%ai_skills_prompt"
                                   HBox.hgrow="ALWAYS" styleClass="input-dark"/>
                        <Button fx:id="aiSuggestBtn" text="%advice_from_ai"
                                onAction="#handleAiSuggest" styleClass="ai-btn"/>
                    </HBox>
                    <ProgressIndicator fx:id="aiLoadingIndicator"
                                       visible="false" managed="false"
                                       prefWidth="30" prefHeight="30"/>
                    <VBox fx:id="aiResultsBox" spacing="0" visible="false" managed="false">
                        <Label fx:id="aiResultsTitle"
                               text="%ai_results_title_text"
                               styleClass="ai-results-title"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>

        <HBox styleClass="popup-footer">
            <Button text="%cancel_btn" onAction="#handleCancel" styleClass="btn-cancel"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="createBtn" text="%create_task_btn_text" onAction="#handleCreateTask"
                    styleClass="btn-create"/>
        </HBox>

    </VBox>
</StackPane>
