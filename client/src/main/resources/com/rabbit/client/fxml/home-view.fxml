<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #09263E; -fx-background: #09263E; -fx-border-color: transparent;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rabbit.client.ui.controllers.HomePageController">
    <VBox spacing="25" style="-fx-background-color: transparent; -fx-padding: 30;">

        <Label text="%homepage" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>

        <VBox spacing="15">
            <Label text="%recent_projects" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <FlowPane fx:id="projectsContainer" hgap="20" vgap="20" />
        </VBox>

        <VBox fx:id="tasksSection" spacing="15">
            <Label text="%tasks_expiring"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TableView fx:id="tasksTable" prefHeight="300" styleClass="dark-table"
                       style="-fx-background-color: #253447;
                              -fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: transparent;
                              -fx-background-insets: 0;">
                <columns>
                    <TableColumn fx:id="colTaskName" text="%col_task_name" prefWidth="250" />
                    <TableColumn fx:id="colProject" text="%col_from_project" prefWidth="200" />
                    <TableColumn fx:id="colPriority" text="%col_priority" prefWidth="120" />
                    <TableColumn fx:id="colDueDate" text="%col_due_date" prefWidth="250" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
