<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.rabbit.client.ui.controllers.NotificationCenterController"
      style="-fx-background-color: #0d1b2e;"
      spacing="10"
      prefHeight="600"
      prefWidth="800">
    <padding>
        <Insets top="15" bottom="15" left="15" right="15"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Notification Center"
               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton"
                text="🔄 Refresh"
                style="-fx-padding: 8 16; -fx-background-color: #1e90ff; -fx-text-fill: white; -fx-font-size: 12px; -fx-cursor: hand; -fx-border-radius: 3; -fx-background-radius: 3;"/>
    </HBox>

    <ListView fx:id="notificationListView"
              VBox.vgrow="ALWAYS"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3a5f; -fx-control-inner-background: #0a1628;"/>

    <Label fx:id="emptyStateLabel"
           text="No notifications yet"
           style="-fx-text-fill: #8ab0c2; -fx-font-size: 16px;"
           alignment="CENTER"
           VBox.vgrow="ALWAYS"
           visible="false"/>
</VBox>
