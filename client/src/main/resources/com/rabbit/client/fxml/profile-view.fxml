<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.rabbit.client.ui.controllers.ProfileController"
      style="-fx-background-color: #09263E;"
      alignment="CENTER"
      spacing="20.0">

    <padding>
        <Insets top="50.0" bottom="50.0" left="50.0" right="50.0"/>
    </padding>

    <Label text="USER PROFILE" style="-fx-text-fill: #fcfcfc; -fx-font-size: 32px; -fx-font-weight: bold;"/>

    <VBox spacing="10.0" alignment="CENTER_LEFT"
          style="-fx-background-color: #1a2533; -fx-padding: 20; -fx-background-radius: 10;">
        <Label fx:id="nameLabel" text="Name: " style="-fx-text-fill: white; -fx-font-size: 18px;"/>
        <Label fx:id="emailLabel" text="Email: " style="-fx-text-fill: white; -fx-font-size: 18px;"/>
        <Label fx:id="roleLabel" text="Role: " style="-fx-text-fill: #ff79c6; -fx-font-size: 18px; -fx-font-weight: bold;"/>
    </VBox>

    <Button fx:id="logoutButton" text="LOGOUT"
            style="-fx-background-color: #ff5555; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 30 10 30; -fx-background-radius: 5;"
            onAction="#handleLogout"/>
</VBox>