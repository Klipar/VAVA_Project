<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.AddUserPopupController"
           styleClass="overlay"
           onMouseClicked="#handleOverlayClick">

                <VBox fx:id="popupCard"
                    maxWidth="460"
                    prefWidth="420"
                    maxHeight="600"
          fillWidth="true"
          alignment="CENTER"
          StackPane.alignment="CENTER"
          spacing="0"
          onMouseClicked="#consumeClick"
          styleClass="popup-card">

        <HBox alignment="CENTER" spacing="12" styleClass="popup-header">
            <Label text="ADD USER" styleClass="popup-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" fitToHeight="true" styleClass="popup-scroll">
            <VBox spacing="18" styleClass="popup-body admin-popup-body">
                <padding>
                    <Insets top="24" left="24" right="24" bottom="18"/>
                </padding>

                <VBox spacing="6" styleClass="admin-field-card">
                    <Label text="LOGIN" styleClass="field-label"/>
                    <TextField fx:id="loginField" promptText="Type user login" styleClass="input-white"/>
                </VBox>

                <VBox spacing="6" styleClass="admin-field-card">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Type password" styleClass="input-white"/>
                </VBox>

                <VBox spacing="10">
                    <Label text="USER MODE" styleClass="field-label"/>
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="admin-radio-row">
                        <RadioButton fx:id="workerRoleRadio" text="Worker" selected="true"/>
                        <RadioButton fx:id="teamLeaderRoleRadio" text="Team Leader"/>
                        <RadioButton fx:id="managerRoleRadio" text="Manager"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>

        <HBox style="-fx-background-color: #0f1c2a; -fx-background-radius: 0 0 16 16; -fx-padding: 16 18 18 18;">
            <Button text="Cancel" onAction="#handleCancel" styleClass="btn-cancel"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="createBtn" text="Create user" onAction="#handleCreate" styleClass="btn-create"/>
        </HBox>

    </VBox>
</StackPane>
