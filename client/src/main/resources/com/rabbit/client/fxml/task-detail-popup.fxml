<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.TaskDetailPopupController"
           styleClass="overlay"
           onMouseClicked="#handleOverlayClick">

    <VBox alignment="CENTER" pickOnBounds="false">

        <VBox fx:id="popupCard"
              maxWidth="620"
              prefWidth="580"
              maxHeight="820"
              spacing="0"
              onMouseClicked="#consumeClick"
              styleClass="popup-card">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="popup-header">
                <Label fx:id="taskTitleLabel" styleClass="popup-title" text="Task_Name"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="editBtn" text="✎" styleClass="edit-icon-btn"
                        onAction="#handleEdit" visible="false" managed="false"/>
                <Button text="✕" onAction="#handleClose" styleClass="close-btn"/>
            </HBox>

            <!-- View Mode (read-only) -->
            <VBox fx:id="viewModeBox" VBox.vgrow="ALWAYS" spacing="0">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="popup-scroll">
                    <VBox spacing="20" styleClass="popup-body">
                        <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

                        <!-- Description -->
                        <VBox spacing="8">
                            <Label fx:id="viewDescriptionLabel" styleClass="field-label"/>
                            <TextArea fx:id="viewDescription"
                                      editable="false"
                                      wrapText="true"
                                      prefHeight="100"
                                      styleClass="input-white"
                                      style="-fx-opacity: 1;"/>
                        </VBox>

                        <Separator styleClass="divider"/>

                        <!-- Status and Priority row -->
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-box"
                                  style="-fx-padding: 10 20; -fx-min-width: 220;">
                                <Label fx:id="viewStatusLabel" styleClass="status-label"/>
                                <Label fx:id="viewStatus" styleClass="status-value" text="IN REVIEW"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-box"
                                  style="-fx-padding: 10 20; -fx-min-width: 220;">
                                <Label fx:id="viewPriorityLabel" styleClass="status-label"/>
                                <Label fx:id="viewPriority" text="HIGH"
                                       style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                            </HBox>
                        </HBox>

                        <!-- Deadline -->
                        <HBox spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: #0a1f33; -fx-background-radius: 10; -fx-padding: 12 20; -fx-border-color: #3E6273; -fx-border-radius: 10; -fx-border-width: 2.5;">
                            <ImageView fitWidth="20" fitHeight="20">
                                <Image url="@../images/calendar.png"/>
                            </ImageView>
                            <Label fx:id="viewDeadline" text="TUE, 07.03.2026, 23:59"
                                   style="-fx-text-fill: #ccd9e0; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Reporter and Assignee -->
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #0a1f33; -fx-background-radius: 10; -fx-padding: 12 16; -fx-border-color: #3E6273; -fx-border-radius: 10; -fx-border-width: 2.5;">
                                <Label fx:id="viewReporterLabel" styleClass="status-label" style="-fx-font-weight: bold;"/>
                                <Label fx:id="viewReporter" text="Mamut R."
                                       style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <ImageView fitWidth="22" fitHeight="22">
                                    <Image url="@../images/user.png"/>
                                </ImageView>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: #0a1f33; -fx-background-radius: 10; -fx-padding: 12 16; -fx-border-color: #3E6273; -fx-border-radius: 10; -fx-border-width: 2.5;">
                                <Label fx:id="viewAssigneeLabel" styleClass="status-label" style="-fx-font-weight: bold;"/>
                                <Label fx:id="viewAssignee" text="Mamut R."
                                       style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <ImageView fitWidth="22" fitHeight="22">
                                    <Image url="@../images/user.png"/>
                                </ImageView>
                            </HBox>
                        </HBox>

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Edit Mode -->
            <VBox fx:id="editModeBox" VBox.vgrow="ALWAYS" spacing="0" visible="false" managed="false">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="popup-scroll">
                    <VBox spacing="18" styleClass="popup-body">
                        <padding><Insets top="24" left="24" right="24" bottom="16"/></padding>

                        <!-- Task name field -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="editTaskNameLabel" styleClass="field-label" minWidth="100"/>
                            <TextField fx:id="editTitleField" HBox.hgrow="ALWAYS" styleClass="input-white"/>
                        </HBox>

                        <!-- Description -->
                        <VBox spacing="6">
                            <Label fx:id="editDescriptionLabel" styleClass="field-label"/>
                            <TextArea fx:id="editDescriptionField"
                                      wrapText="true"
                                      prefHeight="100"
                                      styleClass="input-white"/>
                        </VBox>

                        <Separator styleClass="divider"/>

                        <!-- Deadline -->
                        <HBox spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: #0a1f33; -fx-background-radius: 10; -fx-padding: 12 20; -fx-border-color: #3E6273; -fx-border-radius: 10; -fx-border-width: 2.5;">
                            <ImageView fitWidth="20" fitHeight="20">
                                <Image url="@../images/calendar.png"/>
                            </ImageView>
                            <DatePicker fx:id="editDeadlinePicker"
                                        HBox.hgrow="ALWAYS"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="date-input"
                                        style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
                        </HBox>

                        <!-- Status and Priority -->
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="status-box"
                                  style="-fx-padding: 10 20; -fx-min-width: 220;">
                                <Label fx:id="editStatusStaticLabel" styleClass="status-label"/>
                                <Label fx:id="editStatusLabel" text="IN REVIEW" styleClass="status-value"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="priority-box-container"
                                  style="-fx-padding: 10 14;">
                                <Label fx:id="editPriorityLabel" styleClass="status-label"/>
                                <HBox fx:id="editPriorityBox" spacing="8" alignment="CENTER"/>
                            </HBox>
                        </HBox>

                        <Separator styleClass="divider"/>

                        <!-- Assignee -->
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <Label fx:id="editAssignedLabel" styleClass="field-label" minWidth="80"/>
                            <ComboBox fx:id="editAssigneeCombo"
                                      maxWidth="1.7976931348623157E308"
                                      HBox.hgrow="ALWAYS"
                                      styleClass="combo-input"/>
                        </HBox>

                        <!-- AI Section -->
                        <VBox spacing="12" styleClass="ai-card">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="🐇" styleClass="ai-icon"/>
                                <Label text="%ai_results_title_text" styleClass="ai-header-text"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER">
                                <TextField fx:id="editSkillsField"
                                           promptText="%ai_skills_prompt"
                                           HBox.hgrow="ALWAYS" styleClass="input-dark"/>
                                <Button fx:id="editAiSuggestBtn" text="%advice_from_ai"
                                        onAction="#handleAiSuggest" styleClass="ai-btn"/>
                            </HBox>
                            <ProgressIndicator fx:id="editAiLoadingIndicator"
                                               visible="false" managed="false"
                                               prefWidth="30" prefHeight="30"/>
                            <VBox fx:id="editAiResultsBox" spacing="0" visible="false" managed="false">
                                <Label fx:id="editAiResultsTitle"
                                       text="%ai_results_title_text"
                                       styleClass="ai-results-title" visible="false" managed="false"/>
                            </VBox>
                        </VBox>

                    </VBox>
                </ScrollPane>

                <!-- Edit Footer -->
                <HBox styleClass="popup-footer" spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="cancelEditBtn" onAction="#handleCancelEdit" styleClass="btn-cancel"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteTaskBtn" onAction="#handleDeleteTask" styleClass="btn-danger"/>
                    <Button fx:id="saveBtn" onAction="#handleSaveChanges" styleClass="btn-create"/>
                </HBox>
            </VBox>

        </VBox>

    </VBox>
</StackPane>