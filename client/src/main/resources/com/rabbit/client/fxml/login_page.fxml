<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rabbit.client.ui.controllers.LoginPageController"
      style="-fx-background-color: #0b1a32;">

    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: #0b1a32;">

        <ImageView fitWidth="600" preserveRatio="true">
            <image>
                <Image url="@/com/rabbit/client/images/Rabbit_logo.png"/>
            </image>
        </ImageView>

    </StackPane>

    <VBox alignment="CENTER"
          spacing="20"
          prefWidth="400"
          HBox.hgrow="ALWAYS"
          style="-fx-background-color: #0b1a32; -fx-padding: 60px;">

        <Label text="WELCOME"
               style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>

        <Label fx:id="errorLabel"
               text=""
               style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;"/>

        <TextField fx:id="emailField"
                   promptText="LOGIN"
                   maxWidth="300"
                   style="-fx-background-color: #e0e0e0;
                          -fx-background-radius: 6;
                          -fx-padding: 12px 16px;
                          -fx-font-size: 14px;"/>

        <PasswordField fx:id="passwordField"
                       promptText="PASSWORD"
                       maxWidth="300"
                       style="-fx-background-color: #e0e0e0;
                              -fx-background-radius: 6;
                              -fx-padding: 12px 16px;
                              -fx-font-size: 14px;"/>

        <Button fx:id="loginBtn"
                text="LOGIN"
                prefWidth="300"
                prefHeight="45"
                onAction="#handleLogin"
                style="-fx-background-color: #6c757d;
                       -fx-text-fill: white;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 6;"/>

        <Label text="CONTACT US"
               style="-fx-text-fill: #b0b0b0; -fx-font-size: 12px;"/>
    </VBox>

</HBox>