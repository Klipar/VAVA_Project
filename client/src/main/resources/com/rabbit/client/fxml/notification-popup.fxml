<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.rabbit.client.ui.controllers.NotificationPopupController"
      style="-fx-background-color: #1a2a3a; -fx-border-color: #6a5acd; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;"
      spacing="10"
      prefWidth="400"
      maxWidth="400">
    <padding>
        <Insets top="15" bottom="15" left="15" right="15"/>
    </padding>


    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="📬 Inbox"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeButton"
                text="✕"
                style="-fx-padding: 5 10; -fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 14px; -fx-cursor: hand;"
                onAction="#handleClose"/>
    </HBox>


    <ScrollPane fx:id="notificationsScrollPane"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: #1a2a3a; -fx-control-inner-background: #1a2a3a; -fx-border-color: transparent;"
                fitToWidth="true">
        <VBox fx:id="notificationsContainer"
              spacing="10"
              style="-fx-padding: 10; -fx-background-color: #1a2a3a;"/>
    </ScrollPane>


    <Button fx:id="lessButton"
            text="Open Notification Center"
            style="-fx-padding: 10 20; -fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-radius: 5; -fx-background-radius: 5; -fx-min-width: 100%;"/>
</VBox>


