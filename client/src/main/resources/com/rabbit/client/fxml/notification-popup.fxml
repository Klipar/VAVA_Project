<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.NotificationPopupController"
           style="-fx-background-color: rgba(0,0,0,0.6);"
           onMouseClicked="#handleOverlayClick">

    <VBox fx:id="popupCard"
          maxWidth="450"
          prefWidth="420"
          maxHeight="600"
          fillWidth="true"
          alignment="CENTER"
          spacing="0"
          onMouseClicked="#consumeClick"
          style="-fx-background-color: #0d1b2e; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 10);">

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 16 20 10 20; -fx-background-color: #091420; -fx-background-radius: 12 12 0 0;">
            <Label fx:id="inboxLabel" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButton" onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-text-fill: #8ab0c2; -fx-font-size: 16px; -fx-cursor: hand;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: #0d1b2e; -fx-background-color: #0d1b2e; -fx-border-color: transparent;">
            <VBox fx:id="notificationsContainer" spacing="8"
                  style="-fx-padding: 12 16 12 16; -fx-background-color: #0d1b2e;"/>
        </ScrollPane>

        <HBox spacing="10" alignment="CENTER_RIGHT"
              style="-fx-padding: 12 20 16 20; -fx-background-color: #091420; -fx-background-radius: 0 0 12 12;">
            <Button fx:id="refreshButton"
                    style="-fx-background-color: #1e90ff; -fx-text-fill: white; -fx-font-size: 12px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 6 14;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" style="-fx-text-fill: #8ab0c2; -fx-font-size: 12px;"/>
        </HBox>
    </VBox>
</StackPane>