<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            styleClass="admin-scroll"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rabbit.client.ui.controllers.CreateProjectController">

    <VBox spacing="20" styleClass="admin-root">
        <padding><Insets top="40" left="60" right="60" bottom="40"/></padding>

        <Label text="%create_project_title" styleClass="admin-page-title"/>

        <VBox spacing="20" styleClass="admin-main-card">
            <padding><Insets top="30" left="30" right="30" bottom="30"/></padding>

            <Label text="%name_new_project" styleClass="admin-field-label"/>
            <TextField fx:id="nameField" styleClass="input-white"/>

            <Separator styleClass="divider"/>

            <Label text="%description" styleClass="admin-field-label"/>
            <TextArea fx:id="descriptionField" prefHeight="120" styleClass="input-white"/>

            <Separator styleClass="divider"/>

            <Label text="%deadline" styleClass="admin-field-label"/>
            <DatePicker fx:id="deadlinePicker" promptText="%select_deadline"
                        maxWidth="1.7976931348623157E308" styleClass="date-input"/>

            <Label text="%assigned_label" styleClass="admin-field-label"/>

            <VBox spacing="0">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="assignField" prefWidth="400"
                               promptText="%assigned_label"
                               styleClass="input-white"/>
                    <Button fx:id="addAssignBtn" text="+" onAction="#handleAddAssign"
                            styleClass="assign-add-btn"/>
                </HBox>

                <ListView fx:id="suggestionsListView"
                          prefWidth="400"
                          maxHeight="180"
                          visible="false"
                          managed="false"
                          styleClass="assign-suggestions"/>
            </VBox>

            <FlowPane fx:id="assignedChipsPane" hgap="10" vgap="10"/>

        </VBox>

        <Button text="%create_project_btn" onAction="#handleCreateProject"
                maxWidth="1.7976931348623157E308"
                styleClass="create-project-btn"/>

    </VBox>
</ScrollPane>
