<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.AdminController"
           styleClass="admin-overlay-host">
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="admin-scroll">
        <content>
            <VBox spacing="18" styleClass="admin-root admin-shell">
                <padding>
                    <Insets top="24" right="24" bottom="28" left="24"/>
                </padding>

                <VBox spacing="0" styleClass="admin-main-card">
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="admin-main-header">
                        <Label text="Admin panel" styleClass="admin-page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="openAddUserButton" text="Add new user" styleClass="admin-primary-button" onAction="#openAddUserPopup"/>
                    </HBox>

                    <VBox spacing="10" styleClass="admin-main-body">
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="admin-search-panel-inline">
                            <Label text="Search:" styleClass="admin-inline-label"/>
                            <TextField fx:id="searchLoginField" promptText="" HBox.hgrow="ALWAYS" styleClass="admin-search-field"/>
                            <Button fx:id="searchButton" text="⌕" prefWidth="28" prefHeight="28" styleClass="admin-search-icon-button" accessibleText="Search user" onAction="#handleSearchUser"/>
                        </HBox>

                        <VBox spacing="6" styleClass="admin-summary-card">
                            <TableView fx:id="usersTable" styleClass="admin-users-table" VBox.vgrow="ALWAYS" prefHeight="460">
                                <columns>
                                    <TableColumn fx:id="loginColumn" text="Login" prefWidth="140"/>
                                    <TableColumn fx:id="nameColumn" text="Full name" prefWidth="175"/>
                                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
                                    <TableColumn fx:id="roleColumn" text="Role" prefWidth="90"/>
                                    <TableColumn fx:id="actionsColumn" text="Action" prefWidth="70"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</StackPane>