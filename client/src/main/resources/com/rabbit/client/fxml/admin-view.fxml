<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="admin-scroll"
            fx:controller="com.rabbit.client.ui.controllers.AdminController">
    <content>
        <VBox spacing="24" styleClass="admin-root">
            <padding>
                <Insets top="18" right="24" bottom="28" left="24"/>
            </padding>

            <Label text="Admin panel" styleClass="admin-page-title"/>

            <VBox spacing="16" styleClass="admin-card">
                <Label text="Add user" styleClass="admin-card-title"/>

                <VBox spacing="10">
                    <VBox spacing="6" styleClass="admin-form-group">
                        <Label text="Enter login:" styleClass="admin-field-label"/>
                        <TextField fx:id="addLoginField" promptText="Type user login" styleClass="admin-text-field"/>
                    </VBox>

                    <VBox spacing="6" styleClass="admin-form-group">
                        <Label text="Enter password:" styleClass="admin-field-label"/>
                        <PasswordField fx:id="addPasswordField" promptText="Type password" styleClass="admin-text-field"/>
                    </VBox>
                </VBox>

                <Button fx:id="createUserButton" text="Create user" maxWidth="Infinity" styleClass="admin-primary-button"/>
            </VBox>

            <VBox spacing="16" styleClass="admin-card">
                <Label text="Edit user" styleClass="admin-card-title"/>

                <VBox spacing="14">
                    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="admin-search-row">
                        <VBox spacing="6" HBox.hgrow="ALWAYS" styleClass="admin-form-group admin-search-group">
                            <Label text="Enter login to find:" styleClass="admin-search-label"/>
                            <TextField fx:id="searchLoginField" promptText="Search login" styleClass="admin-search-field"/>
                        </VBox>

                        <Button fx:id="searchButton" text="⌕" prefWidth="46" prefHeight="46" styleClass="admin-search-button" accessibleText="Search user"/>
                    </HBox>

                    <GridPane hgap="20" vgap="14">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="admin-field-card">
                            <Label text="Login:" styleClass="admin-mini-label"/>
                            <TextField fx:id="editLoginField" promptText="Login" styleClass="admin-mini-field"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="admin-field-card">
                            <Label text="Email:" styleClass="admin-mini-label"/>
                            <TextField fx:id="editEmailField" promptText="Email" styleClass="admin-mini-field"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="admin-field-card">
                            <Label text="Full name:" styleClass="admin-mini-label"/>
                            <TextField fx:id="editFullNameField" promptText="Full name" styleClass="admin-mini-field"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="admin-field-card">
                            <Label text="Password:" styleClass="admin-mini-label"/>
                            <PasswordField fx:id="editPasswordField" promptText="Password" styleClass="admin-mini-field"/>
                        </VBox>
                    </GridPane>

                    <HBox spacing="24">
                        <Button fx:id="deleteUserButton" text="Delete user" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: linear-gradient(to bottom, #e07a9e, #c65f85); -fx-text-fill: white; -fx-font-size: 19px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-padding: 12 20 12 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.16), 10, 0, 0, 2);"/>
                        <Button fx:id="saveChangesButton" text="Save changes" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: linear-gradient(to bottom, #7ccf9f, #5db583); -fx-text-fill: white; -fx-font-size: 19px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-padding: 12 20 12 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.16), 10, 0, 0, 2);"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>