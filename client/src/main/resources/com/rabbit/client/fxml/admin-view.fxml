<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:id="overlayPane"
           fx:controller="com.rabbit.client.ui.controllers.AdminController"
           styleClass="admin-overlay-host">
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="admin-scroll">
        <content>
            <VBox spacing="18" styleClass="admin-root admin-shell">
                <padding>
                    <Insets top="24" right="24" bottom="28" left="24"/>
                </padding>

                <VBox spacing="0" styleClass="admin-main-card">
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="admin-main-header">
                        <Label text="ADMIN PANEL" styleClass="admin-page-title" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="openAddUserButton" text="Add new user" styleClass="admin-primary-button" onAction="#openAddUserPopup"/>
                    </HBox>

                    <VBox spacing="15" styleClass="admin-main-body">
                        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="admin-search-panel-inline">
                            <Label text="Search by:" styleClass="admin-inline-label" style="-fx-font-size: 14px;"/>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <RadioButton fx:id="searchByLoginRadio" text="Login" selected="true"/>
                                <RadioButton fx:id="searchByNameRadio" text="Name"/>
                                <RadioButton fx:id="searchByEmailRadio" text="Email"/>
                            </HBox>
                            <TextField fx:id="searchLoginField" promptText="Enter search query..." HBox.hgrow="ALWAYS"
                                       styleClass="admin-search-field" style="-fx-font-size: 14px; -fx-padding: 8;"/>
                            <Button fx:id="searchButton" onAction="#handleSearchUser" styleClass="admin-search-icon-button">
                                <graphic>
                                    <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                        <Image url="@/com/rabbit/client/images/icons/search.png"/>
                                    </ImageView>
                                </graphic>
                            </Button>
                        </HBox>

                        <VBox spacing="6" styleClass="admin-summary-card">
                            <TableView fx:id="usersTable" styleClass="admin-users-table" VBox.vgrow="ALWAYS" prefHeight="550">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="loginColumn" text="Login" prefWidth="150"/>
                                    <TableColumn fx:id="nameColumn" text="Full name" prefWidth="220"/>
                                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="250"/>
                                    <TableColumn fx:id="roleColumn" text="Role" prefWidth="130"/>
                                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="110"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</StackPane>